# ============================================================
# GoldBook MT5 Worker — Environment Variables
# Copy this to .env and fill in your values
# ============================================================

# ── MetaTrader 5 Credentials ─────────────────────────────────
# Your MT5 account login number (the number shown in MT5 title bar)
MT5_LOGIN=12345678

# INVESTOR password (read-only — NOT your master password)
# In MT5: Right-click account > Account Properties > Investor password
MT5_PASSWORD=your_investor_password_here

# Broker server name (shown in MT5 login screen)
MT5_SERVER=ICMarkets-Demo

# Optional: Full path to terminal64.exe if auto-detection fails
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ── Supabase Credentials ─────────────────────────────────────
# From Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co

# Use SERVICE ROLE key (not anon key) for backend scripts — no RLS bypass needed
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...your_service_role_key

# ── GoldBook User & Account IDs ──────────────────────────────
# Get these from Supabase Table Editor after you log in once
USER_ID=your-user-uuid-from-auth-users-table
ACCOUNT_ID=your-account-uuid-from-accounts-table

# ── Settings ─────────────────────────────────────────────────
# How often to sync (in seconds). 30 is recommended.
POLL_INTERVAL=30
